---
import { getEntry } from "astro:content";
import AboutMe from "../components/AboutMe.astro";
import Achievements from "../components/Achievements.astro";
import AdditionalInfo from "../components/AdditionalInfo.astro";
import ContactInfo from "../components/ContactInfo.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Professional from "../components/Professional.astro";
import Skills from "../components/Skills.astro";
import "../styles/style.css";

const resumeEntry = await getEntry("resumes", "data");
const resume = resumeEntry?.data;
const basics = resume?.basics;
const pageTitle = basics?.name ? `Résumé | ${basics.name}` : "Résumé";
const description =
  basics?.summary ?? (basics?.name ? `Professional résumé for ${basics.name}.` : "Professional résumé.");
const ogImageUrl = "/og.png";
---

<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content="Senior Software Engineer & Writer" />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content="Senior Software Engineer & Writer" />
    <meta name="twitter:image" content={ogImageUrl} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="page-shell">
      <Header name={basics?.name} label={basics?.label} profiles={basics?.profiles} />

      <main class="resume-main">
        <section class="resume-overview-section">
          <div class="container resume-overview">
            <AboutMe summary={basics?.summary} label={basics?.label} />
            <ContactInfo
              email={basics?.email}
              phone={basics?.phone}
              url={basics?.url}
              location={basics?.location}
              profiles={basics?.profiles}
            />
            <Skills skills={resume?.skills} />
          </div>
        </section>

        <Professional work={resume?.work} />
        <Achievements education={resume?.education} awards={resume?.awards} />
        <AdditionalInfo projects={resume?.projects} />
      </main>

      <Footer name={basics?.name} profiles={basics?.profiles} />
    </div>
  </body>
</html>

<style>
  .page-shell {
    display: grid;
    min-height: 100svh;
    padding-top: calc(12rem + (var(--space-6) * 2) + 2.75rem);
  }

  .resume-main {
    --resume-card-bg: var(--surface-raised);
    --resume-card-border: var(--border);
    --resume-raised-shadow: 0 1px 2px rgb(15 23 42 / 0.06);

    display: grid;
    gap: var(--space-12);
    padding-bottom: var(--space-12);
  }

  :global(:root[data-theme="dark"]) .resume-main {
    --resume-card-border: var(--border-strong);
    --resume-raised-shadow: 0 1px 2px rgb(0 0 0 / 0.35);
  }

  .resume-overview-section {
    background: var(--section-overview);
    padding-block: var(--space-12);
  }

  .resume-overview {
    display: grid;
    gap: var(--space-12);
  }

  .resume-overview > :global(.resume-card),
  :global(.resume-section),
  :global(.resume-projects-section) {
    background: var(--resume-card-bg);
    border-color: var(--resume-card-border);
    border-radius: var(--radius-md);
    box-shadow: var(--resume-raised-shadow);
  }

  .resume-overview > :global(.resume-card) {
    border: 1px solid var(--resume-card-border);
    padding: var(--space-8);
  }

  @media (min-width: 48rem) {
    .resume-overview {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 40rem) {
    :global(.resume-section),
    :global(.resume-projects-section) {
      border-radius: 0;
      border-inline: 0;
    }
  }
</style>
