---
import SectionHeading from "./SectionHeading.astro";

interface Props {
  summary?: string;
  label?: string;
}

const { summary, label } = Astro.props;
---

<article class="resume-card">
  <SectionHeading icon="user" level={3} text="About Me" />
  <div class="prose">
    <p>
      {
        summary ||
          `Software engineer focused on ${label?.toLowerCase() ?? "building reliable, human-centered software"}.`
      }
    </p>
  </div>
</article>

<style>
  .resume-card {
    display: grid;
    gap: var(--space-4);
  }

  .prose {
    display: grid;
    gap: var(--space-4);
    color: var(--text);
  }
</style>
