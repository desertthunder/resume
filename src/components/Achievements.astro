---
import { formatResumeDate, formatResumeDateRange } from '../utils/date';
import Icon from './Icon.astro';
import SectionHeading from './SectionHeading.astro';

type Education = {
  institution?: string;
  studyType?: string;
  area?: string;
  startDate?: string;
  endDate?: string;
  url?: string;
};

type Award = {
  title?: string;
  date?: string;
  awarder?: string;
  summary?: string;
};

interface Props {
  education?: Education[];
  awards?: Award[];
}

const { education = [], awards = [] } = Astro.props;
const hasItems = education.length > 0 || awards.length > 0;
---

{hasItems && (
  <section class="resume-section" aria-labelledby="achievements-heading">
    <div class="container resume-section__inner">
      <SectionHeading class="resume-section__heading" icon="academic" level={2} text="Achievements" />

      <div class="resume-section__items">
        {education.map((item) => (
          <article class="detail-panel">
            <div class="detail-panel__header">
              <h3>{item.studyType}{item.area ? `, ${item.area}` : ''}</h3>
              <div class="detail-panel__meta">
                <Icon name="academic" />
                {item.institution}{item.startDate ? `, ${item.endDate ? formatResumeDateRange(item.startDate, item.endDate) : formatResumeDate(item.startDate)}` : ''}
              </div>
            </div>
            <hr class="resume-separator" />
          </article>
        ))}

        {awards.map((award) => (
          <article class="detail-panel">
            <div class="detail-panel__header">
              <h3>{award.title}</h3>
              <div class="detail-panel__meta">
                <Icon name="academic" />
                {award.awarder}{award.date ? `, ${formatResumeDate(award.date)}` : ''}
              </div>
            </div>
            {award.summary && <p>{award.summary}</p>}
            <hr class="resume-separator" />
          </article>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .resume-section {
    border: 1px solid var(--border);
    background: var(--surface);
    padding-block: var(--space-12);
  }

  .resume-section__inner {
    display: grid;
    gap: var(--space-8);
  }

  :global(.resume-section__heading) {
    justify-content: center;
  }

  .resume-section__items {
    display: grid;
    gap: var(--space-8);
  }

  .detail-panel {
    display: grid;
    gap: var(--space-4);
  }

  .detail-panel__header {
    display: grid;
    gap: var(--space-1);
  }

  .detail-panel__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    color: var(--text-muted);
    font-size: var(--text-lg);
    font-weight: 700;
    letter-spacing: 0.01em;
  }

  .resume-separator {
    width: 100%;
    border: 0;
    border-top: 1px solid var(--border);
  }

  .resume-section__items > :last-child .resume-separator {
    display: none;
  }
</style>
