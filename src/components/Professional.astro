---
import type { ResumeWork } from '../types/resume';
import { formatResumeDateRange } from "../utils/date";
import SectionHeading from "./SectionHeading.astro";

type Props = { work?: ResumeWork[] };

const { work = [] } = Astro.props;
---

{
  work.length > 0 && (
    <section class="resume-section" aria-labelledby="professional-heading">
      <div class="container resume-section__inner">
        <SectionHeading class="resume-section__heading" icon="briefcase" level={2} text="Professional Experience" />

        <div class="resume-section__items">
          {work.map((job) => (
            <article class="detail-panel">
              <h3>
                {job.url ? (
                  <a class="detail-panel__title-link" href={job.url}>
                    {job.name}
                  </a>
                ) : (
                  job.name
                )}
              </h3>

              <div class="role-row">
                <div class="role-row__title">{job.position}</div>
                <div class="role-row__dates">{formatResumeDateRange(job.startDate, job.endDate)}</div>
              </div>

              {(job.summary || job.highlights?.length) && (
                <div class="prose">
                  <ul>
                    {job.summary && (
                      <li>
                        <strong>{job.summary}</strong>
                      </li>
                    )}
                    {job.highlights?.map((highlight) => (
                      <li>{highlight}</li>
                    ))}
                  </ul>
                </div>
              )}
              <hr class="resume-separator" />
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}

<style>
  .resume-section {
    width: min(calc(100% - 2.5rem), var(--container));
    margin-inline: auto;
    border: 1px solid var(--border);
    background: var(--section-professional);
    padding-block: var(--space-12);
  }

  .resume-section__inner {
    display: grid;
    gap: var(--space-8);
  }

  @media (max-width: 40rem) {
    .resume-section {
      width: 100%;
    }
  }

  :global(.resume-section__heading) {
    justify-content: center;
  }

  .resume-section__items {
    display: grid;
    gap: var(--space-8);
  }

  .detail-panel {
    display: grid;
    gap: var(--space-4);
  }

  .detail-panel__title-link {
    text-decoration: none;
  }

  .detail-panel__title-link:hover {
    color: var(--link);
  }

  .role-row {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-2) var(--space-6);
  }

  .role-row__title {
    font-size: var(--text-lg);
    font-weight: 800;
    line-height: var(--leading-tight);
  }

  .role-row__dates {
    color: var(--text-muted);
    font-size: var(--text-sm);
    letter-spacing: 0.03em;
    white-space: nowrap;
  }

  .prose {
    display: grid;
    gap: var(--space-4);
    color: var(--text);
  }

  .prose ul {
    display: grid;
    gap: var(--space-1);
    padding-left: var(--space-4);
  }

  .prose li::marker {
    color: var(--text-subtle);
  }

  .resume-separator {
    width: 100%;
    border: 0;
    border-top: 1px solid var(--border);
  }

  .resume-section__items > :last-child .resume-separator {
    display: none;
  }
</style>
