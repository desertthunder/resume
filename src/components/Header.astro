---
import type { ResumeProfile } from "../types/resume";
import Icon from "./Icon.astro";

type Props = { name?: string; label?: string; profiles?: ResumeProfile[] };
const { name = "Résumé", label, profiles = [] } = Astro.props;
---

<header class="site-header">
  <div class="container site-header__inner">
    <div class="site-header__identity">
      <h1>{name}</h1>
      {label && <h2 class="site-header__title">{label}</h2>}
    </div>

    <nav class="site-header__links" aria-label="Résumé links">
      <button
        class="site-header__link site-header__theme-toggle"
        type="button"
        aria-label="Toggle dark mode"
        data-theme-toggle>
        <Icon class="site-header__theme-icon" name="sun" data-theme-icon="sun" hidden />
        <Icon class="site-header__theme-icon" name="moon" data-theme-icon="moon" />
      </button>
      <a class="site-header__link site-header__link--primary" href="/resume.pdf" target="_blank">View PDF</a>
      <a class="site-header__link" href="https://github.com/desertthunder/resume" target="_blank"> Source </a>
    </nav>
  </div>
</header>

<script>
  const root = document.documentElement;
  const toggle = document.querySelector<HTMLButtonElement>("[data-theme-toggle]");
  const sunIcon = document.querySelector<HTMLElement>('[data-theme-icon="sun"]');
  const moonIcon = document.querySelector<HTMLElement>('[data-theme-icon="moon"]');
  const storageKey = "resumania-theme";

  const getSystemTheme = () => (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
  const getStoredTheme = () => localStorage.getItem(storageKey) as "light" | "dark" | null;
  const getCurrentTheme = () =>
    root.dataset.theme === "dark"
      ? "dark"
      : root.dataset.theme === "light"
        ? "light"
        : (getStoredTheme() ?? getSystemTheme());

  const applyTheme = (theme: "light" | "dark") => {
    root.dataset.theme = theme;
    localStorage.setItem(storageKey, theme);
    toggle?.setAttribute("data-theme", theme);
    toggle?.setAttribute("aria-label", theme === "dark" ? "Switch to light mode" : "Switch to dark mode");

    if (sunIcon && moonIcon) {
      sunIcon.hidden = theme !== "dark";
      moonIcon.hidden = theme !== "light";
    }
  };

  applyTheme(getStoredTheme() ?? getSystemTheme());

  toggle?.addEventListener("click", () => {
    applyTheme(getCurrentTheme() === "dark" ? "light" : "dark");
  });
</script>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--surface) 92%, transparent);
    padding-block: var(--space-12);
  }

  .site-header__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
    text-align: center;
  }

  .site-header__identity {
    display: grid;
    gap: var(--space-2);
  }

  .site-header__title {
    color: var(--text-muted);
    font-size: var(--text-3xl);
  }

  .site-header__links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-3);
  }

  .site-header__link {
    display: inline-flex;
    min-height: 2.5rem;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    background: var(--surface-raised);
    color: var(--text-muted);
    font-weight: 700;
    padding: var(--space-2) var(--space-4);
    cursor: pointer;
    text-decoration: none;
    transition:
      border-color 160ms ease,
      color 160ms ease,
      transform 160ms ease;
  }

  .site-header__theme-toggle {
    width: 2.5rem;
    height: 1.5rem;
    padding-inline: var(--space-2);
  }

  :global(.site-header__theme-icon[hidden]) {
    display: none !important;
  }

  .site-header__link--primary {
    border-color: var(--accent-6);
    background: var(--accent-6);
    color: white;
  }

  .site-header__link:hover {
    border-color: var(--accent-7);
    color: var(--link);
    transform: translateY(-1px);
  }

  .site-header__link--primary:hover {
    background: var(--accent-7);
    color: white;
  }

  @media (min-width: 48rem) {
    .site-header__inner {
      flex-direction: row;
      text-align: left;
    }

    .site-header__identity {
      flex: 1;
    }
  }
</style>
