---
import type { ResumeProfile } from "../types/resume";
import Icon from "./Icon.astro";

type Props = { name?: string; label?: string; profiles?: ResumeProfile[] };
const { name = "Résumé", label, profiles = [] } = Astro.props;
---

<header class="site-header" data-collapsible-header>
  <div class="container site-header__inner">
    <div class="site-header__avatar" aria-hidden="true">
      <img src="/avatar.jpg" alt="" width="328" height="328" />
    </div>

    <div class="site-header__identity">
      <h1>{name}</h1>
      {label && <h2 class="site-header__title">{label}</h2>}
    </div>

    <nav class="site-header__links" aria-label="Résumé links">
      <button
        class="site-header__link site-header__theme-toggle"
        type="button"
        aria-label="Toggle dark mode"
        data-theme-toggle>
        <Icon class="site-header__theme-icon" name="sun" data-theme-icon="sun" hidden />
        <Icon class="site-header__theme-icon" name="moon" data-theme-icon="moon" />
      </button>
      <a class="site-header__link site-header__link--primary" href="/resume.pdf" target="_blank">View PDF</a>
      <a class="site-header__link" href="https://github.com/desertthunder/resume" target="_blank"> Source </a>
    </nav>
  </div>
</header>

<script>
  const root = document.documentElement;
  const toggle = document.querySelector<HTMLButtonElement>("[data-theme-toggle]");
  const sunIcon = document.querySelector<HTMLElement>('[data-theme-icon="sun"]');
  const moonIcon = document.querySelector<HTMLElement>('[data-theme-icon="moon"]');
  const storageKey = "resumania-theme";
  const header = document.querySelector<HTMLElement>("[data-collapsible-header]");
  const collapseAt = 120;
  const expandAt = 40;

  const getSystemTheme = () => (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
  const getStoredTheme = () => localStorage.getItem(storageKey) as "light" | "dark" | null;
  const getCurrentTheme = () =>
    root.dataset.theme === "dark"
      ? "dark"
      : root.dataset.theme === "light"
        ? "light"
        : (getStoredTheme() ?? getSystemTheme());

  const applyTheme = (theme: "light" | "dark") => {
    root.dataset.theme = theme;
    localStorage.setItem(storageKey, theme);
    toggle?.setAttribute("data-theme", theme);
    toggle?.setAttribute("aria-label", theme === "dark" ? "Switch to light mode" : "Switch to dark mode");

    if (sunIcon && moonIcon) {
      sunIcon.hidden = theme !== "dark";
      moonIcon.hidden = theme !== "light";
    }
  };

  applyTheme(getStoredTheme() ?? "light");

  toggle?.addEventListener("click", () => {
    applyTheme(getCurrentTheme() === "dark" ? "light" : "dark");
  });

  const syncHeaderState = () => {
    if (!header) return;
    const isCollapsed = header.hasAttribute("data-collapsed");

    if (!isCollapsed && window.scrollY > collapseAt) {
      header.setAttribute("data-collapsed", "");
    } else if (isCollapsed && window.scrollY < expandAt) {
      header.removeAttribute("data-collapsed");
    }
  };

  syncHeaderState();
  window.addEventListener("scroll", syncHeaderState, { passive: true });
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    right: 0;
    left: 0;
    z-index: 20;
    isolation: isolate;
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--surface) 88%, transparent);
    padding-block: var(--space-6);
    backdrop-filter: blur(12px);
    overflow-anchor: none;
    transition: padding-block 220ms ease;
  }

  .site-header__inner {
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    align-items: center;
    gap: var(--space-4);
    min-height: 12rem;
    text-align: center;
    transition: min-height 220ms ease;
  }

  .site-header__identity {
    grid-column: 1 / -1;
    display: grid;
    gap: var(--space-1);
    justify-items: center;
    min-width: 0;
  }

  .site-header__identity h1 {
    font-size: var(--text-3xl);
    transition: font-size 220ms ease;
  }

  .site-header__title {
    color: var(--text-muted);
    font-size: var(--text-xl);
    transition: font-size 220ms ease;
  }

  .site-header__links {
    grid-column: 1 / -1;
    display: flex;
    flex-wrap: wrap;
    align-self: start;
    justify-self: center;
    justify-content: center;
    gap: var(--space-3);
    margin-top: var(--space-3);
    transition:
      align-self 220ms ease,
      margin-top 220ms ease;
  }

  .site-header__link {
    display: inline-flex;
    min-height: 2.5rem;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    background: var(--surface-raised);
    color: var(--text-muted);
    font-weight: 700;
    padding: var(--space-2) var(--space-4);
    cursor: pointer;
    text-decoration: none;
    transition:
      border-color 160ms ease,
      color 160ms ease,
      transform 160ms ease;
  }

  .site-header__theme-toggle {
    width: 2.5rem;
    height: 1.5rem;
    padding-inline: var(--space-2);
  }

  :global(.site-header__theme-icon[hidden]) {
    display: none !important;
  }

  .site-header__link--primary {
    border-color: var(--accent-6);
    background: var(--accent-6);
    color: white;
  }

  .site-header__link:hover {
    border-color: var(--accent-7);
    color: var(--link);
    transform: translateY(-1px);
  }

  .site-header__link--primary:hover {
    background: var(--accent-7);
    color: white;
  }

  .site-header__avatar {
    position: absolute;
    bottom: calc(var(--space-6) * -1);
    left: 50%;
    display: grid;
    width: clamp(4.25rem, 3.75rem + 2vw, 5.25rem);
    aspect-ratio: 1;
    place-items: center;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--surface);
    box-shadow: 0 1px 2px rgb(15 23 42 / 0.08);
    padding: 0.1875rem;
    transform: translate(-50%, 50%);
    transition:
      bottom 220ms ease,
      left 220ms ease,
      width 220ms ease,
      transform 220ms ease;
  }

  .site-header__avatar img {
    width: 100%;
    height: 100%;
    border-radius: inherit;
    object-fit: cover;
  }

  :global(:root[data-theme="dark"]) .site-header__avatar {
    border-color: var(--border-strong);
    box-shadow: 0 1px 2px rgb(0 0 0 / 0.35);
  }

  .site-header[data-collapsed] {
    padding-block: var(--space-3);
  }

  .site-header[data-collapsed] .site-header__inner {
    min-height: 3.5rem;
  }

  .site-header[data-collapsed] .site-header__avatar {
    bottom: 50%;
    left: 0;
    width: 3.25rem;
    transform: translateY(50%);
  }

  .site-header[data-collapsed] .site-header__identity {
    grid-column: 2;
    align-items: baseline;
    grid-auto-flow: column;
    justify-content: center;
    justify-items: center;
    gap: var(--space-3);
  }

  .site-header[data-collapsed] .site-header__identity h1 {
    font-size: var(--text-xl);
  }

  .site-header[data-collapsed] .site-header__title {
    font-size: var(--text-base);
  }

  .site-header[data-collapsed] .site-header__links {
    grid-column: 3;
    align-self: center;
    justify-self: end;
    gap: var(--space-2);
    margin-top: 0;
  }

  .site-header[data-collapsed] .site-header__link {
    min-height: 2.25rem;
    font-size: var(--text-sm);
    padding: var(--space-1) var(--space-3);
  }

  .site-header[data-collapsed] .site-header__theme-toggle {
    width: 2.25rem;
    padding-inline: var(--space-2);
  }

  @media (max-width: 44rem) {
    .site-header__inner {
      min-height: 12rem;
    }

    .site-header[data-collapsed] .site-header__inner {
      grid-template-columns: 3.25rem minmax(0, 1fr) auto;
      min-height: 3.5rem;
    }
  }
</style>
