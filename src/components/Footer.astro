---
import type { ResumeProfile } from "../types/resume";
import Icon from "./Icon.astro";

type Props = { name?: string; profiles?: ResumeProfile[]; website?: string };

const { name = "Résumé", profiles = [], website = "https://desertthunder.dev" } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    {
      profiles.length > 0 && (
        <nav class="site-footer__links" aria-label="Profiles">
          {profiles.map(
            (profile) =>
              profile.url && (
                <a class="site-footer__icon-link" href={profile.url} target="_blank">
                  <span class="sr-only">
                    {name} on {profile.network}
                  </span>
                  {profile.network?.toLowerCase() === "github" ? (
                    <Icon name="github" />
                  ) : profile.network?.toLowerCase() === "linkedin" ? (
                    <Icon name="linkedin" />
                  ) : profile.network?.toLowerCase() === "sifa" ? (
                    <img class="site-footer__sifa-icon" src="/icons/sifa.svg" alt="" loading="lazy" />
                  ) : (
                    (profile.network ?? profile.username ?? "•").slice(0, 1)
                  )}
                </a>
              ),
          )}
        </nav>
      )
    }

    <div>
      <div>Copyright © {year} <a href={website} target="_blank">{name}</a></div>
      <div class="site-footer__small">Built with ⚡️ & Astro in Austin, TX</div>
      <a class="site-footer__manual" href="/resume.txt">View as PlainText</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    background: color-mix(in srgb, var(--surface) 72%, transparent);
    padding-block: var(--space-8);
    text-align: center;
  }

  .site-footer__inner {
    display: grid;
    gap: var(--space-4);
  }

  .site-footer__links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-3);
  }

  .site-footer__icon-link {
    display: inline-flex;
    width: 3rem;
    height: 3rem;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: var(--accent-6);
    color: white;
    font-weight: 800;
    text-decoration: none;
    transition:
      background 160ms ease,
      transform 160ms ease;
  }

  .site-footer__icon-link:hover {
    background: var(--accent-7);
    transform: translateY(-1px);
  }

  .site-footer__sifa-icon {
    width: 1.65rem;
    height: 1.65rem;
  }

  .site-footer__manual {
    display: inline-block;
    text-transform: lowercase;
    margin-block-end: var(--space-2);
    color: var(--link);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-decoration-color: var(--link-decoration);
    font-weight: 500;
  }

  .site-footer__small {
    color: var(--text-muted);
    font-size: var(--text-sm);
    font-weight: 500;
  }
</style>
